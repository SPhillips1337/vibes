{
  "name": "vibes-tui",
  "version": "0.1.3",
  "description": "High-performance terminal UI for planning and running agentic coding workflows",
  "type": "module",
  "bin": {
    "vibes": "dist/vibes-cli.js"
  },
  "files": [
    "dist/**/*.js",
    "gemma-12b-prompt.md",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "tsc",
    "test:model-prompts": "npm run build && node --test tests/model-prompts.test.mjs",
    "test:settings-layout": "npm run build && node --test tests/settings-layout.test.mjs tests/enhanced-input.test.mjs",
    "prepack": "npm run build",
    "start": "tsx --no-warnings src/index.tsx",
    "dev": "tsx watch --no-warnings --exclude .vibes --exclude dist --clear-screen=false src/index.tsx",
    "mcp-server": "tsx --no-warnings src/mcp/server.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SPhillips1337/vibes.git"
  },
  "homepage": "https://github.com/SPhillips1337/vibes#readme",
  "bugs": {
    "url": "https://github.com/SPhillips1337/vibes/issues"
  },
  "keywords": [
    "agent",
    "ai",
    "cli",
    "ink",
    "llm",
    "ollama",
    "terminal",
    "tui"
  ],
  "author": "Stephen Phillips",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.4.1",
    "dotenv": "^16.4.7",
    "fastmcp": "^4.0.1",
    "glob": "^11.0.1",
    "gpt-tokenizer": "^3.4.0",
    "ink": "^6.0.0",
    "ink-scrollable-list": "^1.5.1",
    "openai": "^4.85.4",
    "react": "^19.0.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "mem0ai": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "mem0ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "jsdom": "^29.1.1",
    "mem0ai": "^2.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
