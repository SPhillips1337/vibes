# Ollama Connection
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_API_KEY=ollama
# Uncomment to bypass SSL certificate validation (useful for expired/self-signed certs)
# NODE_TLS_REJECT_UNAUTHORIZED=0


# Execution Limits
CONTEXT_WINDOW=64000
MAX_STEPS=50
MAX_CONCURRENT_TASKS=1

# Agent Behaviors
THINKING_MODE=enabled
ENABLE_REVIEWER=true
REVIEWER_MODEL=gemma2:27b

# Long-Term Memory (LTM)
MEMORY_ENABLED=true
MEMORY_USER_ID=default

# Experimental
MULTI_AGENT_ENABLED=false

# MCP Keys
GITHUB_PERSONAL_ACCESS_TOKEN=[GITHUB_PERSONAL_ACCESS_TOKEN]
PERPLEXITY_API_KEY=[PERPLEXITY_API_KEY]
NEO4J_URI=neo4j+s://[db_id].databases.neo4j.io
NEO4J_USERNAME=[db_id]
NEO4J_PASSWORD=[NEO4J_PASSWORD']

# Neo4j Codex (for neo4j-semantic-search MCP server)
CODEX_NEO4J_PASSWORD=[NEO4J_PASSWORD]
