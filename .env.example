# Ollama Connection
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_API_KEY=ollama
# Uncomment to bypass SSL certificate validation (useful for expired/self-signed certs)
# NODE_TLS_REJECT_UNAUTHORIZED=0


# Execution Limits
CONTEXT_WINDOW=64000
MAX_STEPS=50
MAX_CONCURRENT_TASKS=1

# Agent Behaviors
THINKING_MODE=enabled
ENABLE_REVIEWER=true
REVIEWER_MODEL=gemma2:27b

# Long-Term Memory (LTM)
MEMORY_ENABLED=true
MEMORY_USER_ID=default

# Experimental
MULTI_AGENT_ENABLED=false

# MCP Keys
GITHUB_PERSONAL_ACCESS_TOKEN=[GITHUB_PERSONAL_ACCESS_TOKEN]
PERPLEXITY_API_KEY=[PERPLEXITY_API_KEY]
NEO4J_URI=neo4j+s://[db_id].databases.neo4j.io
NEO4J_USERNAME=[db_id]
NEO4J_PASSWORD=[NEO4J_PASSWORD']

# Neo4j Codex (for neo4j-semantic-search MCP server)
CODEX_NEO4J_PASSWORD=[NEO4J_PASSWORD]

# Codex RAG Settings (auto-retrieval from Neo4j knowledge graph)
CODEX_ENABLED=true
CODEX_TOP_K=3

# Small-Model Optimization (copy to .vibes/config.json to apply):
# {
#   "OLLAMA_MODEL": "qwen3.5-2b-kimi-and-opus-distillation-i1",
#   "CONTEXT_WINDOW": 16000,
#   "ENABLE_REVIEWER": false,
#   "CODEX_ENABLED": true,
#   "CODEX_TOP_K": 3
# }
