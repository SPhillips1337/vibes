# ── LM Studio / Ollama Connection ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_API_KEY=ollama

# PLANNER_MODEL overrides the model used for mission planning (structured JSON).
# Leave empty to use OLLAMA_MODEL for planning too.
PLANNER_MODEL=
PLANNER_BASE_URL=
PLANNER_API_KEY=

# NODE_TLS_REJECT_UNAUTHORIZED=0

# ── Execution Limits ───────────────────────────────────────────────────────────
CONTEXT_WINDOW=64000
MAX_STEPS=25
MAX_CONCURRENT_TASKS=1

# ── Agent Behaviors ────────────────────────────────────────────────────────────
THINKING_MODE=disabled
YOLO_MODE=false
ENABLE_REVIEWER=true
REVIEWER_MODEL=gemma2:27b
REVIEWER_BASE_URL=
REVIEWER_API_KEY=
AGENT_HOOKS=true
TOOL_EXECUTION_MODE=sequential
DATA_SHARING_MODE=none
CONTEXT_COMPACTION_ENABLED=true
ENABLE_STRUCTURAL_AUDIT=true
ENABLE_ADVERSARIAL_AUDIT=false

# ── Triage Observer ────────────────────────────────────────────────────────────
TRIAGE_ENABLED=false
TRIAGE_MODEL=
TRIAGE_BASE_URL=
TRIAGE_API_KEY=
TRIAGE_INTERVAL=5
TRIAGE_AUTO_STEER=true

# ── Long-Term Memory ───────────────────────────────────────────────────────────
MEMORY_ENABLED=true
LOCAL_MEMORY=false
MEMORY_USER_ID=default

# ── Experimental ───────────────────────────────────────────────────────────────
MULTI_AGENT_ENABLED=false

# ── Codex RAG (Neo4j Knowledge Graph augmentation) ─────────────────────────────
CODEX_ENABLED=true
CODEX_TOP_K=3
# Paths to the LLM-Codex-Reference-Vault scripts (leave empty for default locations)
CODEX_SCRIPT_PATH=
CODEX_PYTHON_PATH=
CODEX_NEO4J_PASSWORD=[NEO4J_PASSWORD]

# ── MCP External Service Keys ──────────────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=[GITHUB_TOKEN]
PERPLEXITY_API_KEY=[PERPLEXITY_API_KEY]

# Neo4j (MCP knowledge graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=[NEO4J_PASSWORD]

# ── TRACE_DIR (optional, for execution traces) ─────────────────────────────────
# TRACE_DIR=./traces

# ── Small-Model Profile (copy to .vibes/config.json) ───────────────────────────
